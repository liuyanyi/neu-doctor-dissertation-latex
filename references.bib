	url = {https://ieeexplore.ieee.org/document/8526892/},
	doi = {10.1109/MASCOTS.2018.00034},
	abstract = {The rise in popularity of permissioned blockchain platforms in recent time is signiﬁcant. Hyperledger Fabric is one such permissioned blockchain platform and one of the Hyperledger projects hosted by the Linux Foundation [13]. The Fabric comprises of various components such as smartcontracts, endorsers, committers, validators, and orderers. As the performance of blockchain platform is a major concern for enterprise applications, in this work, we perform a comprehensive empirical study to characterize the performance of Hyperledger Fabric and identify potential performance bottlenecks to gain a better understanding of the system.},
	language = {en},
	urldate = {2021-09-28},
